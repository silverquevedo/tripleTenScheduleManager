{
  "name": "schedule-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:backup": "bash scripts/backup.sh",
    "db:check": "sqlite3 prisma/dev.db 'PRAGMA integrity_check; SELECT count(*) || \" shifts\" FROM \"Shift\"; SELECT count(*) || \" members\" FROM \"Member\"; SELECT count(*) || \" programs\" FROM \"Program\";'",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.19.0",
    "@types/nodemailer": "^8.0.0",
    "next": "14.2.5",
    "next-auth": "^4.24.7",
    "nodemailer": "^7.0.13",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "postcss": "^8",
    "prisma": "^5.19.0",
    "tailwindcss": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
}
